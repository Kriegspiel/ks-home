{
  "requiredStaticRoutes": [
    "/",
    "/leaderboard",
    "/blog",
    "/changelog",
    "/rules",
    "/privacy",
    "/terms"
  ],
  "requiredDynamicRoutes": [
    "/blog/:slug",
    "/changelog/:slug",
    "/rules/:slug"
  ],
  "deprecations": [
    {
      "from": "/posts/:slug",
      "to": "/blog/:slug",
      "status": 308,
      "reason": "Legacy blog route replaced by canonical /blog namespace"
    },
    {
      "from": "/news/:slug",
      "to": "/changelog/:slug",
      "status": 308,
      "reason": "Legacy changelog route replaced by canonical /changelog namespace"
    },
    {
      "from": "/rules/wild-16",
      "to": "/rules/wild16",
      "status": 308,
      "reason": "Canonical Wild16 rules route dropped the hyphen to match product naming"
    },
    {
      "from": "/rules/old",
      "to": null,
      "status": 410,
      "reason": "Retired rules endpoint removed permanently"
    }
  ],
  "notFoundBehavior": {
    "status": 404,
    "fallbackRoute": "/404"
  }
}
